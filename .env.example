POSTGRES_DB=respiratory_lab
POSTGRES_USER=respiratory_user
POSTGRES_PASSWORD=respiratory_pass
DATABASE_URL=postgresql+psycopg2://respiratory_user:respiratory_pass@postgres:5432/respiratory_lab
AIRFLOW_UID=50000
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
APP_ENV=development
SEED_DEMO_DATA=true
API_CORS_ORIGINS=http://localhost:3000
DATASET_ROOT=/workspace/files/Enf. Respiratorias_3ro/Respiratorios/chest_xray
ARTIFACTS_ROOT=/workspace/artifacts
PROMOTION_METRIC=macro_f1

# AWS
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SageMaker Scalable Training
SAGEMAKER_ROLE_ARN=
SAGEMAKER_INSTANCE_TYPE=ml.c5.xlarge
S3_BUCKET=
ECR_REPOSITORY_URL=

# Optional
AWS_KEY_PAIR_NAME=corte3-cnn-key
AWS_MY_IP=0.0.0.0/0
AWS_INSTANCE_TYPE=t3.large
AWS_PROJECT_NAME=corte3-cnn
